		]

		\node[header] (header) at (0,0) {Task Overview};
		\node[task, fill=green!30] (task1) at (-4,-1.5) {Task 1\\Easy\\Find Best\\8 experiments\\10 steps};
		\node[task, fill=yellow!30] (task2) at (0,-1.5) {Task 2\\Medium\\Overfitting\\10 experiments\\15 steps};
		\node[task, fill=red!30] (task3) at (4,-1.5) {Task 3\\Hard\\Suggest\\12 experiments\\20 steps};

		\draw[arrow] (task1) -- node[above] {+1.0} (task2);
		\draw[arrow] (task2) -- node[above] {+0.15/step} (task3);
		\draw[arrow] (task3) -- node[above] {+0.5} (header);

	\end{tikzpicture}
\end{figure}

\begin{table}[h]
	\centering
	\begin{tabular}{@{}lc@{}}
		\toprule
		Action                   & Reward       \\
		\midrule
		Investigate valid        & +0.1         \\
		Investigate already done & +0.0         \\
		Discard overfitting      & +0.15        \\
		Discard good             & -0.1         \\
		Suggest (exact match)    & +0.5         \\
		Suggest (partial)        & +0.15 - 0.35 \\
		Summarize correct        & +1.0         \\
		Summarize wrong          & +0.0         \\
		Invalid action           & -0.05        \\
		Max steps reached        & 0.0          \\
		\bottomrule
	\end{tabular}
\end{table}

